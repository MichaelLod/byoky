# Chrome Web Store
# Get credentials: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
# Enable "Chrome Web Store API" in your project
# Use OAuth Playground (https://developers.google.com/oauthplayground/) to get refresh token
CHROME_EXTENSION_ID=
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=

# Firefox Add-ons (AMO)
# Get credentials: https://addons.mozilla.org/developers/addon/api/key/
AMO_API_KEY=
AMO_API_SECRET=

# App Store Connect (iOS + macOS)
# Create API key: App Store Connect > Users and Access > Integrations > App Store Connect API
# Download the .p8 key file, paste its contents here (replace newlines with \n)
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY=

# Google Play
# Create service account: Google Cloud Console > IAM > Service Accounts
# Grant "Release manager" role in Google Play Console > Setup > API access
# Download the JSON key file and set the path here
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Marketplace admin authentication
ADMIN_SECRET=

# Discord release notifications
# Create webhook: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=
