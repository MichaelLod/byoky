# Byoky Test Environment Variables
# Copy this file to .env.test.local for integration tests.
# Without these, integration tests are skipped and only mocks run.

# Anthropic Setup Token (from `claude login` CLI)
# Long-lived (~1 year), scoped to inference
# ANTHROPIC_SETUP_TOKEN=sk-ant-oat01-...

# Anthropic API Key (standard pay-per-token)
# Uses BYOKY_TEST_ prefix to avoid collision with global ANTHROPIC_API_KEY
# BYOKY_TEST_ANTHROPIC_API_KEY=sk-ant-api03-...

# Chrome Web Store
# Get credentials: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
# Enable "Chrome Web Store API" in your project
# Use OAuth Playground (https://developers.google.com/oauthplayground/) to get refresh token
CHROME_EXTENSION_ID=
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=

# Firefox Add-ons (AMO)
# Get credentials: https://addons.mozilla.org/developers/addon/api/key/
AMO_API_KEY=
AMO_API_SECRET=
