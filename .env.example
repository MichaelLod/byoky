# Chrome Web Store
# Get credentials: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
# Enable "Chrome Web Store API" in your project
# Use OAuth Playground (https://developers.google.com/oauthplayground/) to get refresh token
CHROME_EXTENSION_ID=
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=

# Firefox Add-ons (AMO)
# Get credentials: https://addons.mozilla.org/developers/addon/api/key/
AMO_API_KEY=
AMO_API_SECRET=

# Stripe (Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform wholesale API keys (credit-mode — Byoky proxies using these)
PLATFORM_KEY_ANTHROPIC=
PLATFORM_KEY_OPENAI=
PLATFORM_KEY_GOOGLE=
PLATFORM_KEY_MISTRAL=
PLATFORM_KEY_COHERE=
PLATFORM_KEY_XAI=
PLATFORM_KEY_DEEPSEEK=
PLATFORM_KEY_GROQ=
PLATFORM_KEY_TOGETHER=
PLATFORM_KEY_FIREWORKS=
PLATFORM_KEY_PERPLEXITY=
PLATFORM_KEY_OPENROUTER=
