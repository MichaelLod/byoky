{
  "name": "@byoky/extension",
  "version": "0.7.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "build:safari": "wxt build --browser safari",
    "build:all": "pnpm build && pnpm build:firefox && pnpm build:safari",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .output .wxt dist"
  },
  "license": "MIT",
  "dependencies": {
    "@byoky/core": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@wxt-dev/module-react": "1.1.5",
    "typescript": "^5.7.0",
    "wxt": "^0.19.0"
  }
}
