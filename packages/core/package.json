{
  "name": "@byoky/core",
  "description": "Shared types, crypto, and protocol for Byoky — the BYOK wallet for AI credentials",
  "version": "0.9.4",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MichaelLod/byoky.git",
    "directory": "packages/core"
  },
  "homepage": "https://byoky.com",
  "keywords": ["byoky", "ai", "api-keys", "wallet", "encryption", "llm"],
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "typescript": "^5.7.0",
    "ws": "^8.16.0"
  }
}
