{
  "name": "@byoky/bridge",
  "version": "0.9.3",
  "description": "Local HTTP proxy + native messaging bridge that lets CLI tools (Claude Code, OpenClaw) route through the Byoky wallet",
  "type": "module",
  "main": "dist/host.js",
  "exports": {
    ".": "./dist/host.js",
    "./installer": {
      "types": "./dist/installer.d.ts",
      "import": "./dist/installer.js"
    },
    "./spawner": {
      "types": "./dist/spawner.d.ts",
      "import": "./dist/spawner.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "byoky-bridge": "./bin/byoky-bridge.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "byoky",
    "claude",
    "native-messaging",
    "bridge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MichaelLod/byoky.git",
    "directory": "packages/bridge"
  },
  "dependencies": {
    "@byoky/core": "workspace:*",
    "@byoky/sdk": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/ws": "^8.5.12",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
