{
  "name": "@byoky/openclaw-plugin",
  "version": "0.4.4",
  "description": "Byoky wallet provider plugin for OpenClaw — manage AI API keys from your browser wallet",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "auth-page"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "keywords": [
    "byoky",
    "openclaw",
    "ai",
    "api-key",
    "wallet",
    "plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MichaelLod/byoky.git",
    "directory": "packages/openclaw-plugin"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "openclaw": "^2026.3.13",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
