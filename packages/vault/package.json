{
  "name": "@byoky/vault",
  "version": "0.4.9",
  "description": "Server-side vault for Byoky — store encrypted credentials and proxy LLM API calls",
  "type": "module",
  "main": "dist/server.js",
  "bin": { "byoky-vault": "dist/server.js" },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@byoky/core": "workspace:*",
    "hono": "^4.0.0",
    "@hono/node-server": "^1.19.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
