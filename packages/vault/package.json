{
  "name": "@byoky/vault",
  "version": "0.4.17",
  "private": true,
  "description": "Server-side vault for Byoky — store encrypted credentials and proxy LLM API calls",
  "type": "module",
  "main": "dist/server.js",
  "bin": { "byoky-vault": "dist/server.js" },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@byoky/core": "workspace:*",
    "hono": "^4.0.0",
    "@hono/node-server": "^1.19.0",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "drizzle-kit": "^0.30.0"
  }
}
