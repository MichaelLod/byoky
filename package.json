{
  "name": "byoky",
  "version": "0.1.0",
  "private": true,
  "description": "Bring Your Own Key \u2014 Secure wallet for your AI credentials",
  "scripts": {
    "dev": "pnpm --filter @byoky/extension dev",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @byoky/core build",
    "build:sdk": "pnpm --filter @byoky/sdk build",
    "build:extension": "pnpm --filter @byoky/extension build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "spawn-sync"
    ]
  }
}