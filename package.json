{
  "name": "byoky",
  "version": "0.6.0",
  "private": true,
  "description": "Bring Your Own Key — Secure wallet for your AI credentials",
  "scripts": {
    "dev": "pnpm --filter @byoky/extension dev",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @byoky/core build",
    "build:sdk": "pnpm --filter @byoky/sdk build",
    "build:extension": "pnpm --filter @byoky/extension build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run packages/core/tests/security.test.ts",
    "test:vault": "vitest run packages/vault/tests/integration.test.ts",
    "test:vault:e2e": "vitest run packages/vault/tests/e2e.test.ts",
    "test:live": "vitest run --config vitest.config.live.ts",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "test:e2e": "pnpm build:core && pnpm build:sdk && pnpm build:extension && npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "pnpm build:core && pnpm build:sdk && pnpm build:extension && npx playwright test --config e2e/playwright.config.ts --headed",
    "release": "./scripts/release.sh",
    "release:status": "./scripts/release.sh status",
    "release:retry": "./scripts/release.sh retry"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "spawn-sync"
    ],
    "overrides": {
      "tar": ">=7.5.11",
      "@hono/node-server": ">=1.19.10",
      "node-forge": ">=1.4.0",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "defu": ">=6.1.5",
      "vite": ">=6.4.2"
    }
  },
  "devDependencies": {
    "@lydell/node-pty": "^1.2.0-beta.3",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "chrome-webstore-upload-cli": "^3.5.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0",
    "web-ext": "^10.0.0"
  }
}