{
  "name": "byoky",
  "version": "0.1.0",
  "private": true,
  "description": "Bring Your Own Key — Secure wallet for your AI credentials",
  "scripts": {
    "dev": "pnpm --filter @byoky/extension dev",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @byoky/core build",
    "build:sdk": "pnpm --filter @byoky/sdk build",
    "build:extension": "pnpm --filter @byoky/extension build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "spawn-sync"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}